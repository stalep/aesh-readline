#!/usr/bin/env bash
set -euo pipefail

# Resolve script path even when invoked via PATH as `run`.
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
if [[ "${SCRIPT_SOURCE}" != */* ]]; then
  SCRIPT_SOURCE="$(command -v -- "${SCRIPT_SOURCE}")"
fi
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_SOURCE}")" && pwd -P)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
CLASSES_DIR="${ROOT_DIR}/examples/target/classes"

if [[ ! -d "${CLASSES_DIR}" ]]; then
  echo "Missing directory: ${CLASSES_DIR}"
  echo "Build examples first (eg: run 'mvn package' from the root of the project)."
  exit 1
fi

mapfile -t classes < <(
  cd "${CLASSES_DIR}"
  find . -type f -name '*Example.class' \
    | sed 's#^\./##; s#/#.#g; s#\.class$##' \
    | sort
)

if [[ ${#classes[@]} -eq 0 ]]; then
  echo "No classes ending with Example.class found in ${CLASSES_DIR}"
  exit 1
fi

echo "Available examples:"
for i in "${!classes[@]}"; do
  printf "%2d) %s\n" "$((i + 1))" "${classes[i]}"
done

read -r -p "Select a number to run: " choice
if ! [[ "${choice}" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#classes[@]} )); then
  echo "Invalid selection."
  exit 1
fi

name_of_class="${classes[$((choice - 1))]}"
resolve_jar() {
  local pattern="$1"
  local jar
  jar="$(ls ${pattern} 2>/dev/null | grep -v sources | grep -v javadoc | grep -v tests | head -1)"
  if [[ -z "${jar}" ]]; then
    echo "Missing jar: ${pattern}" >&2
    exit 1
  fi
  echo "${jar}"
}

tty_jar="$(resolve_jar "${ROOT_DIR}/terminal-tty/target/terminal-tty-*.jar")"
api_jar="$(resolve_jar "${ROOT_DIR}/terminal-api/target/terminal-api-*.jar")"
readline_jar="$(resolve_jar "${ROOT_DIR}/readline/target/readline-*.jar")"
classpath="${CLASSES_DIR}:${tty_jar}:${api_jar}:${readline_jar}"

java -cp "${classpath}" "${name_of_class}"
